# Cornerstone 部署环境变量模板
#
# 把本文件复制为 .env：
#     cp .env.example .env
#
# 然后填入真实值。
#
# 严禁把填好凭据的 .env 提交进 Git（.gitignore 已默认忽略）。

# ========== 数据库 ==========

# 数据库类型：sqlite 或 postgres
DB_TYPE=sqlite

# SQLite 文件路径（DB_TYPE=sqlite 时）
DATABASE_URL=./cornerstone.db

# Postgres 连接串（DB_TYPE=postgres 时）
# DATABASE_URL=postgresql://user:password@host:5432/cornerstone

# 数据库连接池
DB_MAX_OPEN=10
DB_MAX_IDLE=5
DB_MAX_LIFETIME=3600

# ========== Docker（docker compose 部署时使用）==========

# Postgres 容器配置（仅 docker compose 部署时需要）
# POSTGRES_USER=cornerstone
# POSTGRES_PASSWORD=（请设置一个强随机值）
# POSTGRES_DB=cornerstone

# 宿主映射端口（docker compose 使用，默认 8080）
# APP_PORT=8080

# ========== 应用配置 ==========

# 服务端口，默认 8080
PORT=8080

# release（默认）或 debug；debug 仅供本地开发使用
SERVER_MODE=release

# 日志级别 (debug / info / warn / error / fatal)
LOG_LEVEL=info

# ========== Master Token ==========

# Master Token 值，用于管理所有其他 Token。
#
# - docker compose 部署：必须设置（docker-compose.yml 要求该变量非空）。
# - 裸机 serve 模式：可留空，但 Master Token 认证将不可用，
#   此时无法通过 CLI 或 API 创建普通 Token。
#
# 生成强随机值示例：openssl rand -base64 32 | head -c 32 | awk '{print "cs_"$0}'
MASTER_TOKEN=

# ========== LLM / AI 助手 ==========

# LLM API Key（OpenAI 兼容 API）
LLM_API_KEY=

# LLM 模型名称，如 gpt-4o、claude-sonnet-4-6
LLM_MODEL=gpt-4o

# 可选，自定义 LLM API 地址（兼容 OpenAI 格式）
LLM_BASE_URL=

# ========== MCP ==========

# MCP HTTP Origin 白名单，多个值用逗号分隔
MCP_ALLOWED_ORIGINS=

# MCP SSE 配置
MCP_SSE_KEEPALIVE_SEC=25
MCP_SSE_RETRY_MS=3000
MCP_SSE_REPLAY_BUFFER=128

# ========== 缓存 ==========

# Redis 连接 URL（可选）。留空则使用内存缓存。
# 格式：redis://user:pass@host:port/db
REDIS_URL=
