# Cornerstone 部署环境变量模板
#
# 把本文件复制为 .env：
#     cp .env.example .env
#
# 然后填入真实值。所有 ${VAR:?...} 标记的变量是 docker-compose.yml 启动必备项，
# 缺失会让 `docker compose up` 直接报错而不是用弱口令默认值。
#
# 严禁把填好凭据的 .env 提交进 Git（.gitignore 已默认忽略）。
# 强随机密钥示例：openssl rand -base64 48

# ========== 必填：数据库 ==========

# Postgres 内部用户名（仅容器内通讯使用；默认 cornerstone）
POSTGRES_USER=cornerstone

# Postgres 密码（必填；使用强随机字符串）
POSTGRES_PASSWORD=

# Postgres 库名
POSTGRES_DB=cornerstone

# ========== 必填：JWT 签名 ==========

# 必填；32 字节以上的强随机字符串。
# 释放到 release 模式且 JWT_SECRET 为空 / 等同默认值时后端会拒绝启动。
JWT_SECRET=

# JWT 过期时间（小时），默认 24
JWT_EXPIRATION=24

# ========== 可选：应用配置 ==========

# 宿主映射端口，默认 8080
APP_PORT=8080

# release（默认）或 debug；debug 仅供本地开发使用
SERVER_MODE=release

# 数据库连接池
DB_MAX_OPEN=10
DB_MAX_IDLE=5
DB_MAX_LIFETIME=3600

# 日志级别 (debug/info/warn/error/fatal); 应用统一输出 JSON 到 stdout, 由容器编排层收集/轮转
LOG_LEVEL=info

# CORS 允许的 origin（多个用逗号分隔，留空 = 同源）
CORS_ORIGIN=

# ========== 可选：MCP / 集成上游 ==========

# MCP HTTP Origin 白名单，多个值用逗号分隔
MCP_ALLOWED_ORIGINS=

# LLM Governor 客户端（如启用 AI 推荐）
LLM_GOVERNOR_URL=
LLM_GOVERNOR_TOKEN=

# 跨系统集成基础地址 + 入站 webhook 通用 token
INTEGRATION_BASE_URLS=
INTEGRATION_SHARED_TOKEN=
