# ============================================
# 项目级 .gitignore - 数据管理平台
# ============================================

# ============================================
# 通用开发环境
# ============================================

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.temp
*.bak

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Backend (Go)
# ============================================

# Go 二进制文件
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试覆盖
coverage/
coverage.html
coverage.out
*.test

# Go 依赖
vendor/

# Go 模块缓存
$GOPATH/pkg/mod/

# IDE
*.code-workspace

# 环境变量
.env
.env.local
.env.*.local

# ============================================
# 数据与存储
# ============================================

# 上传文件目录
uploads/
data/

# 数据库文件（本地开发）
*.db
*.sqlite
*.sqlite3

# ============================================
# 其他
# ============================================

# CI/CD
.github/secrets/

# 临时脚本
tmp/
temp/
script/

# 个人配置
*.code-snippets
.playwright-mcp
.claude
CLAUDE.md
.omc/
