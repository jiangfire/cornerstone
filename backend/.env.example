# Cornerstone Backend Configuration
# Copy this file to .env and fill in your actual values

# ===== 数据库配置 =====
# 数据库类型: postgres 或 sqlite (默认: sqlite)
DB_TYPE=sqlite

# SQLite 文件路径 (Windows 上使用 file:// 前缀或绝对路径)
# 示例:
#   Windows: file://C:/path/to/cornerstone.db 或 ./cornerstone.db (会自动转换为绝对路径)
#   Linux/Mac: ./cornerstone.db 或 /path/to/cornerstone.db
DATABASE_URL=./cornerstone.db

# PostgreSQL connection URL (如果 DB_TYPE=postgres)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/cornerstone?sslmode=disable

# 数据库连接池配置
DB_MAX_OPEN=10
DB_MAX_IDLE=5
DB_MAX_LIFETIME=3600

# ===== 服务器配置 =====
# 服务器模式: debug 或 release
SERVER_MODE=debug

# 服务器端口
PORT=8080

# ===== 日志配置 =====
# 日志级别: debug, info, warn, error, fatal
# 应用统一输出 JSON 到 stdout; 文件 / 轮转交给容器编排层 (docker logs / k8s sidecar)
LOG_LEVEL=info

# ===== Master Token（必填） =====
# Master Token 值，用于管理所有其他 Token
# 示例：openssl rand -base64 32 | head -c 32 | awk '{print "cs_"$0}'
MASTER_TOKEN=

# ===== LLM / AI 助手 =====
# LLM API Key（OpenAI 兼容 API）
LLM_API_KEY=

# LLM 模型名称，如 gpt-4o、claude-sonnet-4-6
LLM_MODEL=gpt-4o

# 可选，自定义 LLM API 地址（兼容 OpenAI 格式）
LLM_BASE_URL=

# ===== 开发环境配置 =====
# 是否启用调试模式
DEBUG=true

# CORS配置 (开发环境)
CORS_ORIGIN=*

# MCP HTTP Origin 白名单，多个值用逗号分隔。
# 非浏览器 MCP 客户端通常不会发送 Origin，可留空。
MCP_ALLOWED_ORIGINS=

# MCP SSE keepalive 间隔（秒）
MCP_SSE_KEEPALIVE_SEC=25

# MCP SSE retry 建议间隔（毫秒）
MCP_SSE_RETRY_MS=3000

# MCP SSE Last-Event-ID 重放缓冲区大小（每用户）
MCP_SSE_REPLAY_BUFFER=128

# ===== 生产环境建议 =====
# 生产环境请使用以下配置:
# SERVER_MODE=release
# DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require
# LOG_LEVEL=warn
